# AI Daily News — 环境变量模板
#
# 使用方法：
#   1. cp .env.example .env
#   2. 按下方说明填入你自己的凭证
#   3. .env 已在 .gitignore 中，不会被 commit

# ────────────────────────────────────────────────────────────────
# 外部 API Key
# ────────────────────────────────────────────────────────────────

# Exa 搜索 API（注册 https://exa.ai 获取，新用户有免费额度）
EXA_API_KEY=

# ────────────────────────────────────────────────────────────────
# Twitter/X 采集（通过 twikit 库用 cookie 登录，无需官方 API）
# 首次运行会要求用户名+密码登录，之后自动使用 cookies.json 保持登录
# ────────────────────────────────────────────────────────────────
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=

# ────────────────────────────────────────────────────────────────
# we-mp-rss 微信公众号 RSS 服务（自建本地 Docker 服务）
# 参考 https://github.com/rachelos/we-mp-rss
# ────────────────────────────────────────────────────────────────
WEMPRSS_BASE_URL=http://localhost:8001

# ────────────────────────────────────────────────────────────────
# 飞书多维表格（Layer 4 同步）
# 在飞书开放平台创建自建应用后获取 App ID / App Secret，并在开通
# bitable:app / bitable:app:readonly 权限后，将 Bot 添加为表格协作者。
# ────────────────────────────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 多维表格 app_token（从表格 URL 中获取：base/<app_token>?table=<table_id>）
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# ────────────────────────────────────────────────────────────────
# 深度报告 / 日报 GitHub 仓库（Layer 4 存储）
# 需要在 GitHub 创建一个独立的 Public/Private 仓库，
# 并在本地 git clone（SSH 免密）到仓库外的工作目录。
# ────────────────────────────────────────────────────────────────
# 本地 clone 路径（必须在本仓库之外）
PRODUCT_ANALYSIS_REPO_DIR=
# GitHub 用户名 / 组织名
PRODUCT_ANALYSIS_OWNER=
# 仓库名
PRODUCT_ANALYSIS_REPO=
# 主分支名（默认 main）
PRODUCT_ANALYSIS_BRANCH=main

# ────────────────────────────────────────────────────────────────
# 其它
# ────────────────────────────────────────────────────────────────

# 日志级别
LOG_LEVEL=INFO

# 可选：指定 Python 解释器绝对路径（run.sh 会优先读取此变量）
# PYTHON_BIN=
