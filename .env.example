# ═══════════════════════════════════════════
# AI Daily News — 环境变量配置
# 复制本文件为 .env 并填入你的真实配置
# ═══════════════════════════════════════════

# ── Exa 搜索 API ──
# 注册: https://exa.ai → Dashboard → API Key
# 免费额度: 新用户 $80，之后 $7/1000 次搜索
# 不设置则跳过 Exa 搜索（11 个定向站点 + 5 条通用搜索无法使用）
EXA_API_KEY=your_exa_api_key_here

# ── Twitter/X 采集（通过 twikit，无需官方 API） ──
# 原理: 使用你自己的 Twitter 账号登录，通过 Twitter 内部 API 搜索推文
# 完全免费，无需 $200/月的 API 付费
#
# 首次使用: 填写账号信息 → 运行采集 → 自动登录并保存 cookies
# 后续使用: 自动读取 data/twitter_cookies.json，无需再输入密码
#
# ⚠️ 注意: 频繁采集可能触发风控，建议控制频率（每日 1-2 次即可）
TWITTER_USERNAME=your_twitter_username
TWITTER_EMAIL=your_email@example.com
TWITTER_PASSWORD=your_password

# ── we-mp-rss 微信公众号服务 ──
# Docker 容器默认运行在 8001 端口（无需修改）
# 启动: cd ../we-mp-rss && ./start.sh start
# 状态: cd ../we-mp-rss && ./start.sh status
# 如果服务不可用，collector 会自动跳过微信渠道
WEMPRSS_BASE_URL=http://localhost:8001

# ── 日志级别 ──
LOG_LEVEL=INFO
